<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- затемнение сверху -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="#66000000"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- затемнение снизу -->
    <item>
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#00000000"
                android:endColor="#CC000000" />
        </shape>
    </item>

</layer-list>